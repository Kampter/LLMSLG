# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# All four variables are read by `llmagent` at startup. CLI flags
# (--api-key, --base-url, --model, --system) override anything in here.
# Exported shell env vars also override `.env` (override=False is the default).

# Required. Token from your provider — keep it private.
OPENAI_API_KEY=sk-replace-me

# Optional. Set this to point at any OpenAI-compatible API. Examples:
#   https://api.openai.com/v1            (OpenAI, the default if unset)
#   https://api.deepseek.com             (DeepSeek)
#   https://api.moonshot.cn/v1           (Moonshot / Kimi)
#   https://open.bigmodel.cn/api/paas/v4 (Zhipu GLM)
OPENAI_BASE_URL=https://api.openai.com/v1

# Required. The model id understood by your provider.
LLMAGENT_MODEL=gpt-4o-mini

# Optional. Falls back to a generic helpful-assistant prompt if unset.
LLMAGENT_SYSTEM_PROMPT=You are a helpful assistant.
