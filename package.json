{
  "name": "llmslg",
  "private": true,
  "version": "0.0.0",
  "description": "LLMSLG monorepo: LLM-driven SLG agent, game server, and landing page.",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:landing": "pnpm --filter @llmslg/landing dev",
    "dev:server": "bash scripts/dev-server.sh",
    "dev:agent": "bash scripts/dev-agent.sh",
    "dev:all": "concurrently \"pnpm:dev:server\" \"pnpm:dev:landing\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "py:lint": "uv run ruff check .",
    "py:format": "uv run ruff format .",
    "py:typecheck": "uv run mypy .",
    "py:test": "uv run pytest",
    "check": "bash scripts/check.sh",
    "bootstrap": "bash scripts/bootstrap.sh"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "concurrently": "^9.2.1",
    "prettier": "catalog:",
    "turbo": "^2.9.14",
    "typescript": "catalog:"
  }
}
